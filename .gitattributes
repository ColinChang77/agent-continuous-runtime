# Normalize line endings to LF everywhere so `prettier --check` and shell
# scripts behave identically on macOS, Linux, and Windows. Without this,
# Windows checkouts convert LF -> CRLF and prettier flags every file.
* text=auto eol=lf

# Shell scripts must stay LF; CRLF breaks them.
*.sh text eol=lf

# Known binaries: never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.tgz binary
